                  <Font name="Chalkduster" size="18.0" />
               </font>
            </Button>
            <Button onAction="#exit" mnemonicParsing="false" prefHeight="39.0" prefWidth="87.0" style="-fx-background-radius: 5; -fx-rotate: -3; -fx-background-color: lightgrey;" text="Quit" textAlignment="CENTER" textFill="#093497">
               <font>
                  <Font name="Chalkduster" size="18.0" />
